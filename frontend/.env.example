# constella — Frontend Environment Configuration
# Copy to .env.local and fill in your values.

# Soroban RPC endpoint (Testnet or local)
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase
NEXT_PUBLIC_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Relay WebSocket URL (for live event feed)
NEXT_PUBLIC_RELAY_URL=ws://localhost:8787

# Contract addresses (deployed via scripts/deploy.sh)
# NEXT_PUBLIC_AGENT_REGISTRY_ID=
# NEXT_PUBLIC_BUDGET_POLICY_ID=
# NEXT_PUBLIC_PAYMENT_ID=
